---
import "../styles/lumen.css";
import DataGen from "../components/DataGen.tsx";

const enabled = Boolean(import.meta.env.VITE_HAW_DATAGEN);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex,nofollow" />
    <title>haw — data generation</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@200;300;400;500;600;700&family=IBM+Plex+Mono:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <main class="container">
      {enabled
        ? <DataGen client:only="react" />
        : <p style="padding:2rem;font-family:'IBM Plex Sans',sans-serif">
            Data generation mode is not enabled in this build.
            Set <code>VITE_HAW_DATAGEN=1</code> when running the dev server.
          </p>
      }
    </main>
  </body>
</html>
